# Copy to .env and fill in your values

# Discord webhook for NEW JOB notifications
DISCORD_WEBHOOK_JOBS=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Discord webhook for BID submissions (account 1)
DISCORD_WEBHOOK_BIDS=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Discord webhook for BID submissions (account 2 - Yevhenii K.)
DISCORD_WEBHOOK_BIDS_2=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# OpenAI (optional): if set, bid generation uses OpenAI instead of local LLM
OPENAI_API_KEY=sk-your-openai-api-key
# Model (default gpt-4o-mini). Use gpt-4o, gpt-4o-mini, etc.
OPENAI_MODEL=gpt-4o-mini
# Optional: custom base URL (e.g. Azure or proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Timeout in seconds for OpenAI bid generation (default 120)
OPENAI_TIMEOUT=120

# Local llama-server (used when OPENAI_API_KEY is not set)
LLAMA_SERVER_URL=http://127.0.0.1:8080
# Timeout in seconds for LLM bid generation (default 300; increase if model is slow)
LLAMA_TIMEOUT=300

# How often to check Workana for new jobs (seconds)
POLL_INTERVAL=300
